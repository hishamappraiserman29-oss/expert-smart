# Expert Smart — Environment Variable Template
# Copy to .env and fill in real values. Never commit .env with real secrets.
#
# All variables listed here are read at runtime. Missing required vars will
# raise ValueError at startup (JWT_SECRET, GOVT_SIGNING_KEY).

# ── Authentication ────────────────────────────────────────────────────────────

# Required. Strong random secret for signing JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-use-a-strong-random-secret

# Optional. JWT token lifetime in seconds. Default: 3600 (1 hour).
JWT_TTL_SECONDS=3600

# ── Government document signing ───────────────────────────────────────────────

# Required. HMAC-SHA256 key for signing government valuation documents.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Test environments: set via pytest monkeypatch — never use a real key in tests.
GOVT_SIGNING_KEY=change-me-use-a-strong-random-signing-key

# ── Admin authorization ───────────────────────────────────────────────────────

# Comma-separated list of user_ids that have admin access.
# These user_ids are matched against the JWT sub claim.
# Example: ADMIN_USER_IDS=alice,operations@example.com
ADMIN_USER_IDS=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins. No wildcards in production.
# If unset, safe local-development origins are used automatically.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Set to "false" to disable rate limiting (test environments only).
# Default: "true" (enabled).
RATE_LIMIT_ENABLED=true

# ── Audit logging ─────────────────────────────────────────────────────────────

# Set to "false" to disable audit logging. Default: "true" (enabled).
AUDIT_ENABLED=true

# Path to the SQLite audit log database. Default: core_engine/audit_log.db
# Example: AUDIT_DB_PATH=/var/data/expert_smart/audit.db
AUDIT_DB_PATH=
